// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// we have 3 relations
// 1- one to one 
// 2- one to many   here in side one to many other side many to one
// 3- many to many
// we create models all props required by default if need something optional add ?
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  username  String    @db.VarChar(100) // max length
  // password String? this optional 
  password  String
  isAdmin   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(200)
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  articleId Int
  userId    Int
  // many to one relation 
  /**
   * /**
   * /**
   * /**
   * /**
   * /**
   * /*
   * fields: This is the Foreign Key in your current (local) model. It is the column that physically exists in this table
   * to store the ID of the other record.
   * references: This is the Primary Key in the other (target) model. It tells Prisma which field in the other
   * table the foreign key points to.
   */
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade) // here we define relation in many side
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // here we define relation in many side
}
